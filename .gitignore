# ═══════════════════════════════════════════════════════════════════════════════
# Mcaster1Studio .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─── CMake build output ───────────────────────────────────────────────────────
build/
build-*/
out/
cmake-build-*/
CMakeUserPresets.json

# ─── Visual Studio ────────────────────────────────────────────────────────────
.vs/
*.vcxproj.user
*.suo
*.sdf
*.opensdf
*.db
*.opendb
*.ipch
x64/
Debug/
Release/
RelWithDebInfo/
MinSizeRel/

# ─── Compiled objects & libraries ─────────────────────────────────────────────
*.obj
*.o
*.lib
*.a
*.dll
*.exe
*.pdb
*.ilk
*.exp
*.idb
*.tlog

# ─── Qt generated ────────────────────────────────────────────────────────────
moc_*.cpp
ui_*.h
qrc_*.cpp
*.moc
*_autogen/

# ─── vcpkg local state ───────────────────────────────────────────────────────
vcpkg_installed/

# ─── Logs & debug output ─────────────────────────────────────────────────────
*.log
debug.log
mcaster1studio_debug.log

# ─── OS & editor artifacts ────────────────────────────────────────────────────
NUL
Thumbs.db
Desktop.ini
.DS_Store
*~
*.swp
*.swo
*.bak
*.tmp
*.orig

# ─── IDE config (user-specific) ──────────────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/launch.json
*.code-workspace

# ─── Snapshots (screenshots, can be re-taken) ─────────────────────────────────
snapshots/

# ─── Plugin output (built from source) ───────────────────────────────────────
plugins/modules/*.dll
plugins/effects/*.dll

# ─── Runtime data (generated at first launch) ─────────────────────────────────
*.db-wal
*.db-shm
